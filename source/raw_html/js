(function() {
    'use strict';

const matchHref = () => {
    const msnCn = /\bhttps?:\/\/www\.msn\.cn\/zh-cn\/\w+\/\w+\/[%-\w]+\/[-\w]+/i;
    const githubPage = /\bhttps?:\/\/\w+\.github\.io/i;
    switch (true) {
        case githubPage.test(window.location.href):
        return 'githubPage';
        case msnCn.test(window.location.href):
        return 'msnCn';
        default:
        return '';
    }
};

const bundleLinkS = (selectRule) => {
    const retrievedElemS = document.querySelectorAll(selectRule);
    const hrefArr = [];

    for (const element of retrievedElemS) {
        const bUtterance = document.createElement('button');
        bUtterance.textContent = 'utterance';
        const br = document.createElement('br');
        element.parentElement.insertBefore(bUtterance, element);
        element.parentElement.insertBefore(br, element);
        hrefArr.push(element.href);
    }
    return hrefArr;
};

if ( matchHref() === 'githubPage') {
    const querySelPath = 
    '#quartz-body > div.center > article.popover-hint > p > a.external';
    const linkS = bundleLinkS(querySelPath);
    console.log(linkS);
}

    // Your code here...
})();